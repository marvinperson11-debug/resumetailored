ANTHROPIC_API_KEY=your_anthropic_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRICE_ID=your_stripe_price_id_here
PORT=3000
RESEND_API_KEY=your_resend_api_key_here
OWNER_EMAIL=your@email.com
# Owner activity alerts (signup, tailoring, new/cancelled subscription, login, download)
# email OWNER_EMAIL by default. Set to "off" to silence them all.
OWNER_ALERTS=on
ADMIN_SECRET=choose_a_long_random_secret_here
# Optional — comma-separated emails treated as subscribers (comped/unlimited).
COMP_EMAILS=
# Optional — path to a Chromium/Chrome binary for Remotion video rendering.
# If unset, the renderer auto-detects `chromium` on PATH, else downloads its own.
REMOTION_BROWSER_EXECUTABLE=
# Optional — resume-video voiceover (free). Piper (natural) is used when
# available, else espeak-ng (robotic). Set RESUME_VIDEO_VOICE=off to disable.
RESUME_VIDEO_VOICE=
# Piper overrides (normally auto-detected; nixpacks installs it on Railway):
PIPER_BIN=
PIPER_VOICE=
PIPER_VOICE_ID=en_US-lessac-medium
PIPER_DATA_DIR=
PIPER_AUTODOWNLOAD=
# Studio-quality voice for the downloadable MP4 (ElevenLabs). When set, paid
# subscribers' videos use it; free users fall back to Piper/espeak. Set
# ELEVENLABS_FREE_TIER=on to give it to everyone (spends credits per video).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_FREE_TIER=
