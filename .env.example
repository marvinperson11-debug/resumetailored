ANTHROPIC_API_KEY=your_anthropic_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRICE_ID=your_stripe_price_id_here
PORT=3000
RESEND_API_KEY=your_resend_api_key_here
OWNER_EMAIL=your@email.com
ADMIN_SECRET=choose_a_long_random_secret_here
# Optional — path to a Chromium/Chrome binary for Remotion video rendering.
# If unset, the renderer auto-detects `chromium` on PATH, else downloads its own.
REMOTION_BROWSER_EXECUTABLE=
# Optional — resume-video voiceover (free). Defaults to espeak-ng if installed.
# Set RESUME_VIDEO_VOICE=off to disable. For higher-quality free TTS, install
# Piper and set both: PIPER_BIN=/path/to/piper PIPER_VOICE=/path/to/voice.onnx
RESUME_VIDEO_VOICE=
PIPER_BIN=
PIPER_VOICE=
